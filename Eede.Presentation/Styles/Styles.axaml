<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:Eede.Presentation.Common">
  <Design.PreviewWith>
    <Border Padding="20">
      <!-- Add Controls for Previewer Here -->
    </Border>
  </Design.PreviewWith>



  <Style Selector="Button.tool">
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Width" Value="22" />
    <Setter Property="Height" Value="22" />
    <Setter Property="Padding" Value="1" />
  </Style>
  <Style Selector="Button.tool > Image">
    <Setter Property="Margin" Value="2" />
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
  </Style>
  <Style Selector="Button.tool:disabled">
    <Setter Property="Opacity" Value="0.5"/>
  </Style>
  <Style Selector="ToggleButton.tool">
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Width" Value="22" />
    <Setter Property="Height" Value="22" />
    <Setter Property="Padding" Value="1" />
  </Style>
  <Style Selector="ToggleButton.tool > Image">
    <Setter Property="Margin" Value="2" />
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
  </Style>

  <!-- Must target ContentPresenter to override Fluent Theme inside layers! -->
  <Style Selector="Button.tool:pointerover /template/ ContentPresenter, ToggleButton.tool:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ToolBackgroundPointerOver}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <!-- Explicit Theme Overrides for Dock Components (Document/Tool Tabs) -->
  <Style Selector="DocumentControl, ToolControl">
    <Setter Property="Background" Value="{DynamicResource SurfaceContainerHighBrush}" />
  </Style>

  <!-- Top Toolbar (Bordered) -->
  <Style Selector="ToggleButton.tool:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ToolBorderedBackgroundChecked}" /> 
    <Setter Property="BorderBrush" Value="{DynamicResource ToolBorderedBorderChecked}" /> 
    <Setter Property="BorderThickness" Value="2" />
  </Style>
  <Style Selector="ToggleButton.tool:checked PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
  </Style>
  <Style Selector="ToggleButton.tool:checked:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ToolBorderedBackgroundPointerOverChecked}" /> 
    <Setter Property="BorderBrush" Value="{DynamicResource ToolBorderedBorderPointerOverChecked}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <!-- Left Pen Tools (Flat, No Border) -->
  <Style Selector="ToggleButton.tool-flat:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ToolFlatBackgroundChecked}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
  </Style>
  <Style Selector="ToggleButton.tool-flat:checked:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ToolFlatBackgroundPointerOverChecked}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
  </Style>
  <Style Selector="ToggleButton.tool:checked Image">
    <!-- Image color inversion if needed (not easy in XAML without effects) -->
  </Style>

  <!-- Tab Visuals (Simple Underline Style) -->
  <Style Selector="TabItem">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>
  <Style Selector="TabItem:selected">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextBrush}" />
  </Style>
  <!-- Highlight the underline (Pipe) with Accent Color - Ensuring it hits Dock Tabs too -->
  <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
    <Setter Property="IsVisible" Value="True" />
    <Setter Property="Height" Value="3" />
    <Setter Property="Margin" Value="2,0" />
    <Setter Property="Opacity" Value="1.0" />
  </Style>
  <!-- Catch any other borders used as selected indicators in Dock -->
  <Style Selector="TabItem:selected /template/ Border">
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>
  <Style Selector="TabItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource SurfaceContainerHighestBrush}" />
  </Style>

  <!-- Global Accent Color Overrides for Input Controls -->
  <Style Selector="ComboBox:focus /template/ Border#HighlightLayer">
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SurfaceContainerHighestBrush}" />
  </Style>

  <Style Selector="RepeatButton.allow">
    <Setter Property="Height" Value="20" />
    <Setter Property="Width" Value="24" />
    <Setter Property="Padding" Value="6 5 6 6" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>
  <Style Selector="Polygon.button-shape">
    <Setter Property="Points" Value="0,0 10,0 5,7"/>
    <Setter Property="Fill" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="Panel.horizontal-separator">
    <Setter Property="Margin" Value="4,0" />
    <Setter Property="Width" Value="2" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Background" Value="{DynamicResource BaseBrush}" />
  </Style>
  <Style Selector="Panel.vertical-separator">
    <Setter Property="Margin" Value="4,0" />
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="2" />
    <Setter Property="Background" Value="{DynamicResource BaseBrush}" />
  </Style>

  <Style Selector="PathIcon.icon">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Margin" Value="2" />
    <Setter Property="common:RenderOptionsHelper.EdgeMode" Value="Aliased" />
  </Style>

  <!-- Dialog Buttons Styles -->
  <Style Selector="Button.primary">
    <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#8eff71"/>
            <GradientStop Offset="1" Color="#2ff801"/>
        </LinearGradientBrush>
    </Setter>
    <Setter Property="Foreground" Value="{DynamicResource AccentContrastBrush}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Padding" Value="12,4"/>
  </Style>

  <Style Selector="Button.primary:pointerover, Button.primary:focus, Button.primary:focus-visible">
    <Setter Property="Background" Value="#2ff801" />
  </Style>

  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="#1bc700" />
  </Style>

  <Style Selector="Button.primary:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SurfaceContainerHighBrush}" />
    <Setter Property="Opacity" Value="0.5" />
  </Style>

  <!-- Global Window and Typography Styles -->
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
  </Style>

  <Style Selector="TextBlock.headline-lg">
    <Setter Property="FontFamily" Value="Space Grotesk, Arial, sans-serif" />
    <Setter Property="FontSize" Value="32" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.label-md">
    <Setter Property="FontFamily" Value="Space Grotesk, Arial, sans-serif" />
    <Setter Property="FontSize" Value="12" />
  </Style>
  <Style Selector="Label.label-md">
    <Setter Property="FontFamily" Value="Space Grotesk, Arial, sans-serif" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="TextBlock.body-sm">
    <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
    <Setter Property="FontSize" Value="12" />
  </Style>
  <Style Selector="Label.body-sm">
    <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Input Fields (Ghost Border) -->
  <Style Selector="TextBox, NumericUpDown">
    <Setter Property="Background" Value="{DynamicResource SurfaceContainerHighestBrush}" />
    <Setter Property="BorderBrush" Value="#33484847" /> <!-- 20% opacity of #484847 -->
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement, NumericUpDown:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
  </Style>

  <!-- Industrial ScrollBars (Thin/Sharp/No-Arrow-Buttons) -->
  <Style Selector="ScrollBar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="MinWidth" Value="{DynamicResource ScrollBarSize}" />
    <Setter Property="MinHeight" Value="{DynamicResource ScrollBarSize}" />
  </Style>
  <Style Selector="ScrollBar /template/ RepeatButton">
    <Setter Property="IsVisible" Value="False" />
  </Style>
  <Style Selector="ScrollBar Thumb">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Background" Value="{DynamicResource ScrollBarPanningThumbBackground}" />
  </Style>
  <Style Selector="ScrollBar Thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource ScrollBarThumbFillPointerOver}" />
  </Style>
  <Style Selector="ScrollBar Thumb:pressed">
    <Setter Property="Background" Value="{DynamicResource ScrollBarThumbFillPressed}" />
  </Style>

  <!-- Industrial Contrast Rules (Black text on Green backgrounds) -->
  <Style Selector="ToggleButton:checked">
    <Setter Property="Foreground" Value="{DynamicResource AccentContrastBrush}" />
  </Style>
  <Style Selector="RadioButton:checked">
    <Setter Property="Foreground" Value="{DynamicResource AccentContrastBrush}" />
  </Style>
  <Style Selector="CheckBox:checked /template/ Path#PART_CheckMark">
    <Setter Property="Fill" Value="{DynamicResource AccentContrastBrush}" />
  </Style>
</Styles>
